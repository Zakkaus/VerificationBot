# Bot configuration
TELEGRAM_TOKEN=your_telegram_bot_token
RECAPTCHA_SECRET=your_recaptcha_server_secret
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
WEBAPP_URL=https://your-mini-app.example.com

# Verification settings
APPROVE_MODE=true          # true = join request flow; false = join-then-mute flow
TEST_TIME=120              # seconds allowed for verification
SHUTUP=true                # mute in group before verification (classic mode only)
BAN=false                  # ban on timeout (true = ban, false = kick only)
BAN_TIME=0                 # temp ban seconds; 0 = permanent
GROUPS=                    # comma-separated group usernames or IDs (empty = all groups)
PROXY=                     # optional proxy URL

# Webhook (leave empty to use polling)
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
WEBHOOK_PATH=/webhook

# Admin dashboard
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_USER=admin
ADMIN_PASS=change_this_password

# Database
DB_PATH=bot.db
